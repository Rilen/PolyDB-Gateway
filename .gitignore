# ==============================================================================
# 🎯 POLYDB-GATEWAY: PROTOCOLO DE GOVERNANÇA (EXAUSTIVO)
# ==============================================================================
# Regra de Ouro: Bloqueie a pasta SEG/, .env, chaves e ambientes virtuais.
# ==============================================================================

# 🔐 SEGURANÇA & SEGREDOS (Zero Trust)
SEG/
.env
*.pem
*.key
*.cert
*.crt
*.pfx

# 🐍 PYTHON & AMBIENTES VIRTUAIS
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
lib/
bin/
include/
dist/
build/
*.egg-info/
.pytest_cache/
.coverage
.mypy_cache/
pip-log.txt
pip-delete-this-directory.txt

# 🐋 DOCKER
*.log
docker/volumes/
.docker/

# 📊 DADOS & DATASETS (Higiene de Dados)
# Dataset local persistente é bloqueado para evitar vazamento de PII (Directus)
data/*.db
data/*.sqlite
data/*.csv
data/*.parquet
data/*.json
!data/.keep

# 📔 NOTEBOOKS & IDEs
.ipynb_checkpoints/
*.ipynb
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# 📝 LOGS & OUTPUTS
logs/
*.log
outputs/
temp/
tmp/
debug/

# ==============================================================================
# Rilen T. L. - DataScience — "Security by Design"
# ==============================================================================
